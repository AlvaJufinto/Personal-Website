---
import Layout from "@/layouts/BlogPost.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import BaseHead from "@/components/ui/BaseHead.astro";
import Header from "@/components/ui/Header.astro";
import Footer from "@/components/ui/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="custom-container">
      <section class="prose prose-slate max-w-none">
        <div class="mb-12">
          <h1
            class="font-primary text-3xl font-bold tracking-tight text-slate-900"
          >
            About Me
          </h1>
          <p class="font-secondary mt-4 text-lg text-slate-600">
            Welcome to my personal blog and portfolio! I write about technology,
            life, faith, and my journey as a Catholic, student, and musician.
          </p>
        </div>

        <hr class="line" />

        <div class="pt-12">
          <div class="grid md:grid-cols-2 gap-12 mb-12">
            <div>
              <h2 class="font-primary text-2xl font-bold text-slate-900 mb-4">
                Who am I?
              </h2>
              <p class="font-secondary text-slate-700 leading-relaxed">
                I'm a <span class="font-semibold text-slate-900"
                  >Computer Science student</span
                >, church organist, and someone who loves to reflect on life's
                changes and responsibilities. My writings are a mix of <span
                  class="font-semibold text-slate-900"
                  >English and Indonesian</span
                >, depending on the topic and mood.
              </p>
            </div>

            <div>
              <h2 class="font-primary text-2xl font-bold text-slate-900 mb-4">
                What do I write?
              </h2>
              <ul class="space-y-2 font-secondary text-slate-700">
                <li class="flex items-start gap-2">
                  <span class="text-slate-900 font-bold mt-1">#</span>
                  <span
                    ><b>Personal Reflections</b> — Life, change, and growth</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-slate-900 font-bold mt-1">#</span>
                  <span
                    ><b>Achievements</b> — Tech competitions & experiences</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-slate-900 font-bold mt-1">#</span>
                  <span
                    ><b>Faith Journey</b> — Catholic reflections & liturgy</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-slate-900 font-bold mt-1">#</span>
                  <span><b>Responsibility</b> — Life struggles & gratitude</span
                  >
                </li>
              </ul>
            </div>
          </div>

          <div class="mb-12">
            <h2 class="font-primary text-2xl font-bold text-slate-900 mb-4">
              Why do I write?
            </h2>
            <p class="font-secondary text-slate-700 leading-relaxed">
              I started this blog to share my journey, both the ups and downs.
              Sometimes, there's no lesson, just stories. I believe that <span
                class="font-semibold text-slate-900"
                >authentic reflection and vulnerability</span
              > can create meaning and connection. I hope my experiences can resonate
              with you, whether you're here for tech, faith, or just a slice of life.
            </p>
          </div>

          <!--<div class="pt-8">
            <h2 class="font-primary text-xl font-bold text-slate-900 mb-6">
              Let's connect!
            </h2>
            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="mailto:stanislaus.alva@gmail.com"
                class="font-secondary inline-flex items-center justify-center px-6 py-3 bg-slate-900 text-white font-semibold hover:bg-slate-800 transition-colors"
              >
                Email
              </a>
              <a
                href="https://www.linkedin.com/in/stanislausalva/"
                class="font-secondary inline-flex items-center justify-center px-6 py-3 border-2 border-slate-900 text-slate-900 font-semibold hover:bg-slate-100 transition-colors"
              >
                LinkedIn
              </a>
            </div>
          </div>-->
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
