---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

import BaseHead from "@/components/ui/BaseHead.astro";
import Footer from "@/components/ui/Footer.astro";
import FormattedDate from "@/components/ui/FormattedDate.astro";
import Header from "@/components/ui/Header.astro";

import { Icon } from "astro-icon/components";

const linkStyles = {
  github: {
    class:
      "border-slate-200 text-slate-700 hover:bg-slate-50 hover:border-slate-300",
    icon: "mdi:github",
  },

  gitlab: {
    class:
      "border-orange-200 text-orange-700 hover:bg-orange-50 hover:border-orange-300",
    icon: "mdi:gitlab",
  },

  deployment: {
    class:
      "border-emerald-200 text-emerald-700 hover:bg-emerald-50 hover:border-emerald-300",
    icon: "mdi:rocket-launch",
  },

  website: {
    class:
      "border-blue-200 text-blue-700 hover:bg-blue-50 hover:border-blue-300",
    icon: "mdi:web",
  },

  figma: {
    class:
      "border-pink-200 text-pink-700 hover:bg-pink-50 hover:border-pink-300",
    icon: "mdi:figma",
  },

  documentation: {
    class:
      "border-purple-200 text-purple-700 hover:bg-purple-50 hover:border-purple-300",
    icon: "mdi:file-document-outline",
  },

  other: {
    class:
      "border-slate-200 text-slate-700 hover:bg-slate-50 hover:border-slate-300",
    icon: "mdi:open-in-new",
  },
};
type Props = CollectionEntry<"work">["data"];

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  logo,
  category = [],
  tech = [],
  links = [],
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="bg-white text-slate-900">
    <Header />

    <main class="custom-container py-10">
      <article class="mx-auto max-w-6xl">
        {
          heroImage && (
            <div class="group relative mb-12 overflow-hidden border border-slate-200 bg-slate-100">
              <Image
                width={1600}
                height={800}
                class="h-auto w-full object-cover transition-transform duration-500 group-hover:scale-[1.01]"
                src={heroImage}
                alt={title}
              />
            </div>
          )
        }

        <div class="space-y-12">
          <section class="border-b border-slate-200 pb-10">
            <div
              class="flex flex-wrap items-center gap-3 text-sm text-slate-500"
            >
              <span class="font-secondary">
                Published <FormattedDate date={pubDate} />
              </span>

              {
                updatedDate && (
                  <span class="font-secondary">
                    • Updated <FormattedDate date={updatedDate} />
                  </span>
                )
              }
            </div>

            <div class="mt-6 flex items-start gap-5">
              {
                logo ? (
                  <div class="flex h-20 w-20 shrink-0 items-center justify-center overflow-hidden rounded-3xl border border-slate-200 bg-white p-3 shadow-sm">
                    <Image
                      src={logo}
                      alt={`${title} app icon`}
                      width={80}
                      height={80}
                      class="h-full w-full object-contain"
                    />
                  </div>
                ) : null
              }

              <div class="min-w-0 flex-1">
                <h1
                  class="font-primary text-4xl font-bold tracking-tight text-slate-900 md:text-5xl lg:text-6xl"
                >
                  {title}
                </h1>

                {
                  description && (
                    <p class="font-secondary mt-5 max-w-4xl text-lg leading-relaxed text-slate-600 md:text-xl">
                      {description}
                    </p>
                  )
                }
              </div>
            </div>

            {
              category.length > 0 && (
                <div class="mt-8">
                  <p class="font-secondary mb-3 text-xs font-medium uppercase tracking-[0.2em] text-slate-400">
                    Topics
                  </p>

                  <div class="flex flex-wrap gap-3">
                    {category.map((item) => (
                      <span class="font-secondary inline-flex items-center border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm text-slate-600">
                        #{item}
                      </span>
                    ))}
                  </div>
                </div>
              )
            }

            {
              tech.length > 0 && (
                <div class="mt-8">
                  <p class="font-secondary mb-3 text-xs font-medium uppercase tracking-[0.2em] text-slate-400">
                    Stack
                  </p>

                  <div class="flex flex-wrap gap-3">
                    {tech.map((item) => (
                      <span class="font-secondary inline-flex items-center border border-blue-200 bg-blue-50 px-3 py-1.5 text-sm font-medium text-blue-700">
                        {item}
                      </span>
                    ))}
                  </div>
                </div>
              )
            }

            {
              links.length > 0 && (
                <div class="mt-8">
                  <p class="font-secondary mb-3 text-xs font-medium uppercase tracking-[0.2em] text-slate-400">
                    Project Links
                  </p>

                  <div class="flex flex-wrap gap-3">
                    {links.map((link) => {
                      const style = linkStyles[link.type] ?? linkStyles.other;

                      return (
                        <a
                          href={link.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class={`font-secondary inline-flex items-center gap-3 border px-4 py-2.5 text-sm transition ${style.class}`}
                        >
                          <div class="flex items-center gap-2">
                            <Icon name={style.icon} class="h-4 w-4" />

                            <span>{link.label}</span>
                          </div>

                          <span class="text-xs uppercase opacity-60">
                            {link.type}
                          </span>
                        </a>
                      );
                    })}
                  </div>
                </div>
              )
            }
          </section>

          <section>
            <div class="markdown">
              <slot />
            </div>
          </section>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>
