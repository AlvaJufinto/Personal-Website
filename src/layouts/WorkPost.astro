---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

import BaseHead from "@/components/ui/BaseHead.astro";
import Footer from "@/components/ui/Footer.astro";
import FormattedDate from "@/components/ui/FormattedDate.astro";
import Header from "@/components/ui/Header.astro";

import { Icon } from "astro-icon/components";

const linkStyles = {
  github: {
    icon: "mdi:github",
    label: "GitHub",
  },
  gitlab: {
    icon: "mdi:gitlab",
    label: "GitLab",
  },
  deployment: {
    icon: "mdi:rocket-launch",
    label: "Live",
  },
  website: {
    icon: "mdi:web",
    label: "Website",
  },
  figma: {
    icon: "mdi:figma",
    label: "Figma",
  },
  documentation: {
    icon: "mdi:file-document-outline",
    label: "Docs",
  },
  other: {
    icon: "mdi:open-in-new",
    label: "Link",
  },
};

type Props = CollectionEntry<"work">["data"];

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  logo,
  category = [],
  tech = [],
  links = [],
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="bg-white text-slate-900">
    <Header />

    <main class="custom-container py-12">
      <article class="mx-auto max-w-4xl">
        {
          heroImage && (
            <div class="group mb-16 overflow-hidden border border-slate-200">
              <Image
                width={1600}
                height={800}
                class="h-auto w-full object-cover  transition-transform duration-700 group-hover:scale-[1.02]"
                src={heroImage}
                alt={title}
              />
            </div>
          )
        }

        <div class="space-y-16">
          <section class="border-b border-slate-100 pb-14">
            <div class="flex items-start gap-5">
              {
                logo && (
                  <div class="flex h-14 w-14 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-slate-100 bg-slate-50 p-2.5">
                    <Image
                      src={logo}
                      alt={`${title} logo`}
                      width={56}
                      height={56}
                      class="h-full w-full object-contain"
                    />
                  </div>
                )
              }

              <div class="min-w-0 flex-1 pt-1">
                <div
                  class="mb-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-400"
                >
                  <FormattedDate date={pubDate} />
                  {
                    updatedDate && (
                      <span>
                        · updated <FormattedDate date={updatedDate} />
                      </span>
                    )
                  }
                </div>

                <h1
                  class="font-primary text-3xl font-semibold leading-tight tracking-tight text-slate-900 md:text-4xl lg:text-5xl"
                >
                  {title}
                </h1>

                {
                  description && (
                    <p class="font-secondary mt-4 max-w-2xl text-lg leading-relaxed text-slate-500">
                      {description}
                    </p>
                  )
                }
              </div>
            </div>

            <div
              class="mt-10 flex flex-col gap-6 sm:flex-row sm:flex-wrap sm:items-start sm:gap-10"
            >
              {
                category.length > 0 && (
                  <div>
                    <p class="font-secondary mb-2 text-xs text-slate-400">
                      Topics
                    </p>
                    <div class="flex flex-wrap gap-x-3 gap-y-1">
                      {category.map((item) => (
                        <span class="font-secondary text-sm text-slate-500">
                          #{item}
                        </span>
                      ))}
                    </div>
                  </div>
                )
              }

              {
                tech.length > 0 && (
                  <div>
                    <p class="font-secondary mb-2 text-xs text-slate-400">
                      Stack
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {tech.map((item) => (
                        <span class="font-secondary rounded bg-slate-50 px-2.5 py-1 text-sm text-slate-600">
                          {item}
                        </span>
                      ))}
                    </div>
                  </div>
                )
              }

              {
                links.length > 0 && (
                  <div>
                    <p class="font-secondary mb-2 text-xs text-slate-400">
                      Links
                    </p>
                    <div class="flex flex-wrap gap-x-4 gap-y-2">
                      {links.map((link) => {
                        const style = linkStyles[link.type] ?? linkStyles.other;
                        return (
                          <a
                            href={link.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="font-secondary inline-flex items-center gap-1.5 text-sm text-slate-600 underline underline-offset-4 decoration-slate-300 transition hover:text-slate-900 hover:decoration-slate-600"
                          >
                            <Icon
                              name={style.icon}
                              class="h-3.5 w-3.5 shrink-0"
                            />
                            {link.label || style.label}
                          </a>
                        );
                      })}
                    </div>
                  </div>
                )
              }
            </div>
          </section>

          <section>
            <div class="markdown">
              <slot />
            </div>
          </section>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>
