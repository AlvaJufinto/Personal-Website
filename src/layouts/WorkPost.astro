---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

import BaseHead from "@/components/ui/BaseHead.astro";
import Footer from "@/components/ui/Footer.astro";
import FormattedDate from "@/components/ui/FormattedDate.astro";
import Header from "@/components/ui/Header.astro";

type Props = CollectionEntry<"work">["data"];

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  category = [],
  tech = [],
  links = [],
} = Astro.props;

const linkStyles = {
  github:
    "border-slate-200 text-slate-700 hover:bg-slate-50 hover:border-slate-300",
  gitlab:
    "border-orange-200 text-orange-700 hover:bg-orange-50 hover:border-orange-300",
  deployment:
    "border-emerald-200 text-emerald-700 hover:bg-emerald-50 hover:border-emerald-300",
  website:
    "border-blue-200 text-blue-700 hover:bg-blue-50 hover:border-blue-300",
  figma: "border-pink-200 text-pink-700 hover:bg-pink-50 hover:border-pink-300",
  documentation:
    "border-purple-200 text-purple-700 hover:bg-purple-50 hover:border-purple-300",
  other:
    "border-slate-200 text-slate-700 hover:bg-slate-50 hover:border-slate-300",
};
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="bg-white text-slate-900">
    <Header />

    <main class="custom-container py-10">
      <article class="mx-auto max-w-5xl">
        {
          heroImage && (
            <div class="group relative mb-10 overflow-hidden border border-slate-200 bg-slate-100">
              <Image
                width={1600}
                height={800}
                class="h-auto w-full object-cover transition-transform duration-500 group-hover:scale-[1.01]"
                src={heroImage}
                alt={title}
              />
            </div>
          )
        }

        <div class="grid gap-10 lg:grid-cols-[240px_minmax(0,1fr)]">
          <aside class="space-y-8">
            <div>
              <p
                class="font-secondary mb-2 text-xs font-medium uppercase tracking-[0.2em] text-slate-400"
              >
                Published
              </p>

              <p class="font-secondary text-sm text-slate-600">
                <FormattedDate date={pubDate} />
              </p>

              {
                updatedDate && (
                  <p class="font-secondary mt-2 text-sm text-slate-500">
                    Updated <FormattedDate date={updatedDate} />
                  </p>
                )
              }
            </div>

            {
              category.length > 0 && (
                <div>
                  <p class="font-secondary mb-3 text-xs font-medium uppercase tracking-[0.2em] text-slate-400">
                    Topics
                  </p>

                  <div class="flex flex-wrap gap-2">
                    {category.map((item) => (
                      <span class="font-secondary inline-flex items-center border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs text-slate-600">
                        #{item}
                      </span>
                    ))}
                  </div>
                </div>
              )
            }

            {
              tech.length > 0 && (
                <div>
                  <p class="font-secondary mb-3 text-xs font-medium uppercase tracking-[0.2em] text-slate-400">
                    Stack
                  </p>

                  <div class="flex flex-wrap gap-2">
                    {tech.map((item) => (
                      <span class="font-secondary inline-flex items-center border border-blue-200 bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700">
                        {item}
                      </span>
                    ))}
                  </div>
                </div>
              )
            }

            {
              links.length > 0 && (
                <div>
                  <p class="font-secondary mb-3 text-xs font-medium uppercase tracking-[0.2em] text-slate-400">
                    Project Links
                  </p>

                  <div class="flex flex-col gap-2">
                    {links.map((link) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class={`font-secondary inline-flex items-center justify-between border px-3 py-2 text-sm transition ${
                          linkStyles[link.type] ?? linkStyles.other
                        }`}
                      >
                        <span>{link.label}</span>

                        <span class="text-xs uppercase opacity-60">
                          {link.type}
                        </span>
                      </a>
                    ))}
                  </div>
                </div>
              )
            }
          </aside>

          <section>
            <div class="mb-10 border-b border-slate-200 pb-8">
              <h1
                class="font-primary mb-5 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl"
              >
                {title}
              </h1>

              {
                description && (
                  <p class="font-secondary max-w-3xl text-lg leading-relaxed text-slate-600">
                    {description}
                  </p>
                )
              }
            </div>

            <div
              class="prose prose-slate prose-lg max-w-none prose-headings:font-primary prose-headings:tracking-tight prose-p:text-slate-700 prose-a:no-underline hover:prose-a:text-slate-900 prose-code:rounded prose-code:bg-slate-100 prose-code:px-1 prose-code:py-0.5 prose-code:text-sm"
            >
              <slot />
            </div>
          </section>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>
