---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

import BaseHead from "@/components/ui/BaseHead.astro";
import Footer from "@/components/ui/Footer.astro";
import FormattedDate from "@/components/ui/FormattedDate.astro";
import Header from "@/components/ui/Header.astro";
import Tags from "@/components/ui/Tags.astro";
import getRecommendedPosts from "@/lib/BlogRecommender";

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  topics = [],
  language,
} = post.data;

const allPosts = await getCollection("blog");

const relatedPosts = getRecommendedPosts(post, allPosts, 3);
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />

    <main class="custom-container">
      {
        heroImage && (
          <div class="mb-8 overflow-hidden">
            <Image
              width={1020}
              height={510}
              class="w-full h-auto"
              src={heroImage}
              alt={title}
            />
          </div>
        )
      }

      <div class="prose prose-slate max-w-none">
        <div class="mb-8">
          <div class="mb-4">
            <p class="font-secondary text-slate-500 text-sm">
              <FormattedDate date={pubDate} />

              {
                updatedDate && (
                  <span class="ml-2">
                    • Last updated on <FormattedDate date={updatedDate} />
                  </span>
                )
              }
            </p>
          </div>

          <h1
            class="font-primary text-3xl font-bold tracking-tight text-slate-900 md:text-4xl mb-4"
          >
            {title}
          </h1>

          {
            description && (
              <p class="font-secondary text-lg text-slate-600 leading-relaxed">
                {description}
              </p>
            )
          }

          <Tags topics={topics} language={language} />
        </div>

        <div class="markdown border-t border-slate-200 pt-8">
          <slot />
        </div>

        {
          relatedPosts.length > 0 && (
            <section class="mt-16 border-t border-slate-200 pt-8">
              <h2 class="font-primary text-2xl font-bold mb-6">
                Related Articles
              </h2>

              <div class="grid gap-6 md:grid-cols-3">
                {relatedPosts.map((relatedPost) => (
                  <a
                    href={`/blog/${relatedPost.id}/`}
                    class="group overflow-hidden border border-slate-200 transition hover:border-slate-400"
                  >
                    {relatedPost.data.heroImage && (
                      <Image
                        src={relatedPost.data.heroImage}
                        alt={relatedPost.data.title}
                        width={600}
                        height={320}
                        class="aspect-video w-full object-cover"
                      />
                    )}

                    <div class="p-4">
                      <p class="mb-2 text-sm text-slate-500">
                        <FormattedDate date={relatedPost.data.pubDate} />
                      </p>

                      <h3 class="font-semibold text-slate-900 group-hover:underline">
                        {relatedPost.data.title}
                      </h3>

                      {relatedPost.data.description && (
                        <p class="mt-2 text-sm text-slate-600 line-clamp-3">
                          {relatedPost.data.description}
                        </p>
                      )}

                      {relatedPost.data.topics && (
                        <div class="mt-4 flex flex-wrap gap-2">
                          {relatedPost.data.topics.map((topic) => (
                            <span class="border border-slate-200 px-2 py-1 text-xs text-slate-600">
                              {topic}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </main>

    <Footer />
  </body>
</html>
