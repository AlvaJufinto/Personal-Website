---
import { Image } from "astro:assets";
import FormattedDate from "./FormattedDate.astro";
import Tags from "./Tags.astro";

const { post } = Astro.props;
---

<article
  class="group overflow-hidden bg-white shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-md hover:ring-slate-300 h-full"
>
  <a href={`/blog/${post.id}/`} class="flex h-full flex-col">
    {
      post.data.heroImage && (
        <div class="aspect-video overflow-hidden">
          <Image
            width={720}
            height={360}
            class="h-full w-full object-cover transition-transform group-hover:scale-105"
            src={post.data.heroImage}
            alt=""
          />
        </div>
      )
    }

    <div class="p-6 flex flex-col flex-1">
      <div class="flex-1">
        <h2
          class="font-primary text-xl font-semibold text-slate-900 group-hover:text-slate-700 transition-colors"
        >
          {post.data.title}
        </h2>

        {
          post.data.description && (
            <p class="font-secondary mt-3 text-slate-600 line-clamp-3 text-xs">
              {post.data.description}
            </p>
          )
        }

        <Tags topics={post.data.topics} language={post.data.language} />
      </div>

      <div class="mt-4">
        <p class="font-secondary text-sm text-slate-500">
          <FormattedDate date={post.data.pubDate} />
        </p>
      </div>
    </div>
  </a>
</article>
