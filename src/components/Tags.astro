---
const { topics, language } = Astro.props;
---

<div class="flex flex-wrap items-center gap-2 my-4">
  {
    topics && topics.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {topics.map((topic: string) => (
          <span class="inline-block bg-slate-100 text-slate-600 text-xs px-2 py-1 font-medium">
            #{topic}
          </span>
        ))}
      </div>
    )
  }
  {
    language && (
      <span class="inline-block bg-blue-100 text-blue-700 text-xs px-2 py-1 font-medium">
        {language === "id" ? "ID" : "EN"}
      </span>
    )
  }
</div>
