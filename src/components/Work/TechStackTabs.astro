---
import { TECH_STACK } from "@/consts";
---

<div>
  <div id="tech-tabs" class="mb-6 flex gap-1 overflow-x-auto">
    {
      TECH_STACK.map((tech, index) => (
        <button
          class:list={[
            "tech-tab",
            "font-primary",
            "capitalize",
            "cursor-pointer",
            "px-3 py-1.5",
            "text-sm",
            "whitespace-nowrap",
            "transition-colors",
            index === 0
              ? "bg-slate-900 text-white"
              : "text-slate-500 hover:text-slate-700 hover:bg-slate-100",
          ]}
          data-tab={tech.type}
        >
          {tech.type}
        </button>
      ))
    }
  </div>

  <div>
    {
      TECH_STACK.map((tech, index) => (
        <div
          data-content={tech.type}
          class:list={["tech-content", index !== 0 && "hidden"]}
        >
          <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
            {tech.stack.map((stack) => (
              <div class="group cursor-pointer flex items-center gap-3 p-3 transition-colors hover:bg-slate-50">
                <img
                  src={stack.logo}
                  alt={stack.name}
                  class="h-7 w-7 object-contain opacity-80 transition-opacity group-hover:opacity-100"
                  loading="lazy"
                />
                <p class="font-secondary text-sm text-slate-600">
                  {stack.name}
                </p>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll<HTMLElement>(".tech-tab");
    const contents = document.querySelectorAll<HTMLElement>(".tech-content");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.tab;

        tabs.forEach((t) => {
          t.classList.remove("bg-slate-900", "text-white");
          t.classList.add("text-slate-500");
        });

        tab.classList.add("bg-slate-900", "text-white");
        tab.classList.remove("text-slate-500");

        contents.forEach((c) => c.classList.add("hidden"));
        document
          .querySelector<HTMLElement>(`[data-content="${target}"]`)
          ?.classList.remove("hidden");
      });
    });
  });
</script>
