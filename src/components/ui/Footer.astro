---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import HumanBadge from "@/assets/icons/human-badge.png";

const today = new Date();

const socials = [
  {
    label: "GitHub",
    href: "https://github.com/AlvaJufinto",
    icon: "mdi:github",
  },

  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/alva-jufinto/",
    icon: "mdi:linkedin",
  },

  {
    label: "Instagram",
    href: "https://www.instagram.com/alva.jufinto/",
    icon: "mdi:instagram",
  },
];
---

<footer class="mt-32 border-t-2 border-slate-100 pb-10 bg-white">
  <div
    class="custom-container flex flex-col gap-12 py-12 lg:flex-row lg:items-end lg:justify-between"
  >
    <!-- Left -->
    <div class="max-w-xl space-y-6">
      <div class="space-y-3">
        <p
          class="font-secondary text-xs font-medium uppercase tracking-[0.25em] text-slate-400"
        >
          Portfolio
        </p>

        <h2
          class="font-primary text-2xl font-bold tracking-tight text-slate-900 md:text-3xl"
        >
          Stanislaus Alva Jufinto.
        </h2>
      </div>

      <p
        class="font-secondary text-base leading-relaxed text-slate-600 md:text-lg"
      >
        Engineer by trade. Indie builder by nature.
      </p>

      <div
        class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500"
      >
        <span>© {today.getFullYear()}</span>

        <span class="hidden h-1 w-1 rounded-full bg-slate-300 md:block"></span>

        <span>All rights reserved</span>
      </div>
    </div>

    <!-- Right -->
    <div class="flex flex-col items-end gap-5">
      <div class="flex flex-wrap items-end gap-3 w-full">
        {
          socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="flex w-full items-center justify-start gap-2 text-sm text-slate-600 transition hover:text-slate-900 lg:justify-end"
            >
              <Icon
                name={social.icon}
                class="h-4 w-4 transition-transform duration-200"
              />

              <span class="font-secondary text-right">{social.label}</span>
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-4">
        <div class="h-px w-10 bg-slate-200"></div>

        <a
          href="https://notbyai.fyi/"
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-70 transition hover:opacity-100"
          aria-label="Human Made Badge"
        >
          <Image height={28} src={HumanBadge} alt="Human Made Badge" />
        </a>
      </div>
    </div>
  </div>
</footer>
